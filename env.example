@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600;700&family=Inter:wght@500;600;700;800;900&display=swap');:root{--green:#092a23;--cream:#f3ecdd;--cream2:#fbf6eb;--ink:#11251f;--copper:#e28d47;--yellow:#f7d56b;--red:#ef4444;--line:rgba(17,37,31,.22)}*{box-sizing:border-box}body{margin:0;background:var(--green);font-family:Inter,system-ui;color:var(--ink)}a{text-decoration:none;color:inherit}.hero-surface,.companion-section{background:radial-gradient(circle at 82% 6%,rgba(255,255,255,.09),transparent 13%),radial-gradient(circle at 24% 26%,rgba(38,96,78,.52),transparent 38%),linear-gradient(135deg,#0b3028,#09271f 62%,#051d18);color:var(--cream);position:relative;overflow:hidden}.hero-layout,.section-inner,.companion-inner,.footer,.country-hero-inner,.detail-layout{max-width:1180px;margin:0 auto;position:relative;z-index:2}.hero-layout{min-height:760px;display:grid;grid-template-columns:1fr 1fr;gap:78px;align-items:center}.kicker{font-size:10px;font-weight:900;letter-spacing:.18em;text-transform:uppercase;color:rgba(244,237,223,.82)}.kicker.dark{color:#54665d}.kicker i{display:inline-block;width:28px;height:1px;background:var(--copper);vertical-align:middle;margin-right:13px}.hero-copy h1,.country-hero h1,.location-hero h1,.hero-layout.single h1{font-family:'Cormorant Garamond';font-size:122px;line-height:.8;letter-spacing:-.055em;margin:24px 0}.hero-copy h1 span{display:block}.hero-copy h1 em{display:block;color:var(--copper);font-style:italic}.lead{font-family:'Cormorant Garamond';font-size:25px;line-height:1.16;color:rgba(244,237,223,.88);max-width:465px}.hero-actions{display:flex;gap:26px;align-items:center;margin-top:34px}.hero-actions a,.back{background:var(--copper);padding:18px 30px;color:#061d18;font-size:11px;letter-spacing:.12em;font-weight:900}.watch-link{background:transparent!important;color:var(--cream)!important;padding:0!important}.setup-note{margin-top:28px;color:var(--yellow);font-size:12px}.route-panel{height:610px;border:1px solid rgba(244,237,223,.34);background:rgba(10,43,35,.34);padding:18px;backdrop-filter:blur(8px)}.phase-tabs{display:flex;gap:8px;margin-bottom:12px}.phase-tabs button{flex:1;background:rgba(244,237,223,.08);border:1px solid rgba(244,237,223,.18);color:rgba(244,237,223,.74);font-size:10px;font-weight:900;letter-spacing:.16em;padding:12px}.phase-tabs button.on{background:var(--cream);color:var(--ink)}.panel-head{display:flex;justify-content:space-between;font-size:10px;font-weight:900;letter-spacing:.13em;color:rgba(244,237,223,.8);border-bottom:1px solid rgba(244,237,223,.16);padding-bottom:15px}.map-area{height:330px;position:relative;overflow:hidden;background-image:linear-gradient(rgba(244,237,223,.05) 1px,transparent 1px),linear-gradient(90deg,rgba(244,237,223,.05) 1px,transparent 1px);background-size:25px 25px}.route-svg{position:absolute;inset:24px;width:calc(100% - 48px);height:calc(100% - 48px)}.land{fill:rgba(244,237,223,.12);stroke:rgba(244,237,223,.28);stroke-width:.75}.land.asia{fill:rgba(226,141,71,.07)}.trail{fill:none;stroke:#c28b62;stroke-width:.7;stroke-dasharray:1.6 1.5}.marker{position:absolute;z-index:3;transform:translate(-50%,-50%);width:44px;height:44px;border-radius:50%;border:1px solid rgba(244,237,223,.7);background:#153a31;color:var(--cream);display:grid;place-items:center;font-size:10px;font-weight:900}.marker.selected{background:#071d18;color:var(--cream);box-shadow:0 0 0 4px rgba(226,141,71,.25)}.marker.current{background:var(--yellow);border-color:var(--yellow);color:#14251f;box-shadow:0 0 0 6px rgba(247,213,107,.18)}.marker.current:after{content:"";position:absolute;inset:-10px;border:2px solid var(--red);border-radius:50%;animation:pulse 1.7s infinite}@keyframes pulse{0%{transform:scale(.8);opacity:.9}100%{transform:scale(1.45);opacity:0}}.map-key{display:flex;gap:14px;align-items:center;font-size:10px;letter-spacing:.12em;font-weight:900;margin:12px 0;color:rgba(244,237,223,.75);flex-wrap:wrap}.live-dot,.route-dot,.selected-dot{width:10px;height:10px;border-radius:50%;display:inline-block}.live-dot{background:var(--yellow);box-shadow:0 0 0 3px rgba(239,68,68,.35)}.route-dot{background:#153a31;border:1px solid rgba(244,237,223,.7)}.selected-dot{background:#071d18}.map-country-strip{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:12px 0}.map-country-strip button{border:1px solid rgba(244,237,223,.16);background:rgba(244,237,223,.07);color:rgba(244,237,223,.78);padding:10px;text-align:left;min-height:62px}.map-country-strip button.current{border-color:var(--yellow)}.map-country-strip button.selected{background:var(--cream);color:var(--ink)}.map-country-strip span,.map-country-strip em{font-size:9px;font-style:normal;font-weight:900;opacity:.7}.map-country-strip b{display:block;font-family:'Cormorant Garamond';font-size:18px}.current-card{background:var(--cream2);color:var(--ink);padding:22px 26px;margin-top:8px}.current-card p{font-size:10px;letter-spacing:.15em;font-weight:900;color:#8c887f;margin:0 0 9px}.current-card h3{font-family:'Cormorant Garamond';font-size:34px;margin:0}.cream-section{background:radial-gradient(circle at 14% 12%,rgba(255,255,255,.75),transparent 20%),var(--cream);color:var(--ink)}.section-inner{padding:92px 0}.archive-grid-head{display:grid;grid-template-columns:1fr 330px;gap:76px}.section-inner h2{font-family:'Cormorant Garamond';font-size:68px;line-height:.95;margin:15px 0}.section-note{font-family:'Cormorant Garamond';font-size:20px;line-height:1.3;color:#3e5149}.country-archive-grid{padding-top:0;display:grid;grid-template-columns:repeat(3,1fr);gap:26px}.country-archive-card{min-height:300px;padding:30px;background:#0b2f27;color:var(--cream);display:flex;flex-direction:column;justify-content:flex-end;position:relative;overflow:hidden}.country-archive-card:before{content:"";position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.08),transparent);opacity:.4}.country-archive-card.muted{filter:grayscale(1);opacity:.42}.country-archive-card.live{background:var(--yellow);color:#14251f;filter:none;opacity:1}.country-archive-card p,.country-archive-card span{font-size:10px;letter-spacing:.16em;font-weight:900;position:relative}.country-archive-card h3{font-family:'Cormorant Garamond';font-size:44px;margin:10px 0;position:relative}.country-archive-card small{position:relative;line-height:1.35}.companion-section{padding:110px 0}.companion-inner{display:grid;grid-template-columns:.9fr 1fr;gap:56px}.companion-copy h2{font-family:'Cormorant Garamond';font-size:58px;line-height:.9}.answer-card{border:1px solid rgba(244,237,223,.26);padding:22px}.answer-head{display:flex;justify-content:space-between;font-size:9px;font-weight:900;letter-spacing:.12em;color:rgba(244,237,223,.58)}.answer-card article{background:var(--cream2);color:var(--ink);padding:36px;margin-top:18px;min-height:220px}.answer-card article h3{font-family:'Cormorant Garamond';font-size:31px}.ask-bar{display:flex;align-items:center;gap:8px;background:var(--cream);padding:12px;margin-top:8px}.ask-bar input{flex:1;background:transparent;border:0}.ask-bar button{background:var(--copper);border:0;padding:12px}.footer{height:74px;background:#0b2f27;color:rgba(244,237,223,.65);display:flex;align-items:center;justify-content:space-between;font-size:10px;letter-spacing:.12em}.country-hero,.location-hero{min-height:520px}.country-hero-inner{padding:95px 0}.crumbs{font-size:10px;font-weight:900;letter-spacing:.12em;margin-bottom:34px;color:rgba(244,237,223,.75)}.crumbs a{color:rgba(244,237,223,.85)}.crumbs span{margin:0 8px;color:var(--copper)}.country-template,.location-template{display:grid;gap:42px}.summary-display{font-family:'Cormorant Garamond';font-size:30px;line-height:1.2;background:#fffaf0;border:1px solid var(--line);padding:24px}.highlight-grid,.location-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}.highlight-grid article,.location-grid a,.admin-card{border:1px solid var(--line);background:#f8f0e2;padding:24px}.highlight-grid h3,.location-grid h3{font-family:'Cormorant Garamond';font-size:30px}.location-grid img{width:100%;height:180px;object-fit:cover;margin-bottom:18px}.detail-layout{display:grid;grid-template-columns:.9fr 1.1fr;gap:70px;padding:95px 0;align-items:center}.detail-image{height:460px;position:relative;overflow:hidden}.detail-image img{width:100%;height:100%;object-fit:cover}.detail-image b{position:absolute;left:24px;bottom:24px;background:var(--cream);padding:16px 20px;color:var(--ink)}.location-template{grid-template-columns:1.1fr .7fr}.blog-copy{font-family:'Cormorant Garamond';font-size:31px;line-height:1.2}.mini-highlight{border:1px solid var(--line);padding:18px;margin-bottom:10px;background:#f8f0e2}.tags{display:flex;gap:8px;flex-wrap:wrap}.tags span{background:#0b2f27;color:var(--cream);padding:8px 10px;font-size:10px}.gallery-link{display:inline-flex;margin-top:24px;background:#0b2f27;color:var(--cream);padding:15px 20px;font-weight:900;font-size:11px}.photo-preview{display:grid;grid-template-columns:repeat(2,1fr);gap:8px;margin-bottom:28px}.photo-preview img{width:100%;height:110px;object-fit:cover}.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}.gallery-grid img{width:100%;height:260px;object-fit:cover}.gallery-grid figcaption{font-size:11px;margin-top:6px}.admin-page{min-height:100vh;background:var(--cream)}.admin-shell{max-width:1120px;margin:0 auto;padding:70px 24px}.back-link{font-weight:900}.admin-shell h1{font-family:'Cormorant Garamond';font-size:84px}.admin-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px}.admin-card.login{max-width:520px}.admin-card h2{font-family:'Cormorant Garamond';font-size:36px}.admin-card label{display:block;font-size:10px;letter-spacing:.14em;font-weight:900;margin:16px 0 10px}.admin-card select,.admin-card input,.admin-card textarea{width:100%;border:1px solid var(--line);background:#fffaf0;padding:14px}.admin-card textarea{height:120px}.admin-card button{margin:10px 10px 0 0;background:#0b2f27;color:var(--cream);border:0;padding:15px 20px;font-weight:900}.admin-card button.busy{background:var(--copper);color:#061d18}.toast{position:sticky;bottom:16px;margin-top:20px;background:#0b2f27;color:var(--cream);display:inline-block;padding:14px 18px;font-weight:900}@media(max-width:980px){.hero-layout,.archive-grid-head,.companion-inner,.detail-layout,.location-template,.admin-grid{grid-template-columns:1fr}.hero-layout{padding:55px 22px}.hero-copy h1,.country-hero h1,.location-hero h1{font-size:78px}.route-panel{height:auto}.map-country-strip,.country-archive-grid,.highlight-grid,.location-grid,.gallery-grid{grid-template-columns:1fr}.section-inner,.country-hero-inner{padding:70px 22px}.footer{height:auto;padding:24px;flex-direction:column;align-items:flex-start}.admin-shell{padding:60px 22px}}
